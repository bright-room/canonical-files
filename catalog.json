    },
    ".github/SECURITY.md": {
      "file_type": "markdown",
      "mode": "replaced"
    },
    ".github/CODE_OF_CONDUCT.md": {
      "file_type": "markdown",
      "mode": "replaced"
    },
    ".github/LICENSE": {
      "file_type": "text",
      "mode": "create-only"
    }
  }
